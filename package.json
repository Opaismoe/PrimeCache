{
  "name": "cache-warmer",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "dev": "pnpm --filter cache-warmer-backend dev",
    "build": "pnpm --filter cache-warmer-backend build && pnpm --filter cache-warmer-frontend build",
    "start": "pnpm --filter cache-warmer-backend start",
    "test": "pnpm --filter cache-warmer-backend test",
    "test:watch": "pnpm --filter cache-warmer-backend test:watch",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  }
}
