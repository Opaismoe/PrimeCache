BROWSERLESS_WS_URL=ws://browserless:3000/chromium/playwright
BROWSERLESS_TOKEN=<secret>
API_KEY=<random-secret-min-16-chars>
SECRET_ENCRYPTION_KEY=<run: openssl rand -hex 32>
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<password-min-8-chars>
DATABASE_URL=postgres://primecache:<password>@postgres:5432/primecache
POSTGRES_PASSWORD=<secret>
CONFIG_PATH=/app/config/config.yaml
PORT=3000
LOG_LEVEL=info
TIMEZONE=Europe/Amsterdam
